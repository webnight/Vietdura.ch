        "max": 10,
        "layout": "block",
        "button_label": "+ Position hinzufügen",
        "conditional_logic": [[{ "field": "field_vd_tm_aktiv", "operator": "==", "value": "1" }]],
        "menu_order": 4,
        "sub_fields": [
          {
            "key": "field_vd_tm_extra_badge",
            "label": "Badge (z.B. \"Menu 1\", \"Suppe\")",
            "name": "badge",
            "type": "text",
            "placeholder": "Menu 1",
            "wrapper": { "width": "30" }
          },
          {
            "key": "field_vd_tm_extra_titel",
            "label": "Gericht",
            "name": "titel",
            "type": "text",
            "placeholder": "z.B. Pho Bo mit Rindfleisch",
            "required": 1,
            "wrapper": { "width": "70" }
          },
          {
            "key": "field_vd_tm_extra_beschreibung",
            "label": "Beschreibung",
            "name": "beschreibung",
            "type": "text",
            "placeholder": "Kurze Beschreibung (optional)",
            "wrapper": { "width": "70" }
          },
          {
            "key": "field_vd_tm_extra_preis",
            "label": "Preis (CHF)",
            "name": "preis",
            "type": "text",
            "placeholder": "18.50",
            "wrapper": { "width": "30" }
          }
        ]
      }
    ],
    "location": [
      [{ "param": "options_page", "operator": "==", "value": "vietdura-tagesmenu" }]
    ],
    "menu_order": 0,
    "position": "normal",
    "style": "default",
    "label_placement": "top",
    "instruction_placement": "label",
    "active": true
