        "label": "Preis-Info",
        "name": "tagesmenu_preis_info",
        "type": "text",
        "instructions": "Wird unter dem Menu angezeigt.",
        "placeholder": "Inkl. Suppe oder Dessert · CHF 18.50 / 21.50",
        "conditional_logic": [[{ "field": "field_vd_tm_aktiv", "operator": "==", "value": "1" }]],
        "menu_order": 3
      },
      {
